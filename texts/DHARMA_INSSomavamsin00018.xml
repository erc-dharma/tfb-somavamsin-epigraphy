         <div type="edition" xml:lang="san-Latn"><!-- update the @xml:lang value, see EGD §7.2-->
            <!--edition encoded as per EGD §§2−7--><!-- text based on SHastri's edition p 251 -->
              <pb n="1v"/>
              <ab><lb n="1"/><g ref="sym:spiral-left" type="symbol">*</g></ab>            
             <lg n="1" met="śārdūlavikrīḍita">
               <l n="a">svasti prema-niruddha-mugdha-manasoḥ sphārībhavac-cakṣuṣo<lb n="2" break="no"/>r</l>
               <l n="b">yūnor yatravicitra-nirbhara-rata-krīḍā-krama<supplied reason="omitted">ṁ</supplied> tanvatoḥ<g ref="sym:bar" type="punctuation">.</g></l>
               <l n="c">vicchinno 'pi kr̥tā<lb n="3" break="no"/>timātra-pulakair āvirbhavat-sītkr̥tair</l>
               <l n="d">āśleṣair glapita-klamaiḥ smara-ra<lb n="4" break="no"/>saḥ kāmaṁ muhustāyyate<!-- apparently same reading as in Soma 23 soma 25 --></l>
             </lg>
             <lg n="2" met="śārdūlavikrīḍita">
                  <l n="a">yatrāśeṣa-vi<choice><orig>s</orig><reg>ś</reg></choice>eṣa-rūpa-mahimāpāstā<lb n="5" break="no"/>psaraḥ kāntibhir</l>
                  <l n="b">jāterṣyā-kalaheṣv api praṇayinaḥ karṇotpalai<lb n="6" break="no"/>s tāḍitāḥ</l>
                  <l n="c">jāyante praviśat-sata-smara-śara-protthāpitāntar-vyathā<supplied reason="omitted">ḥ</supplied></l>
                  <l n="d">s<surplus>y</surplus>āndi<!-- same reading in Soma 23 soma 25  --><lb n="7" break="no"/>-sveda-jalāvasecana-vaśān niryyati-romāṅkurāḥ<g ref="sym:doubleBar" type="punctuation">.</g></l>
               </lg>
            <lg n="3" met="śārdūlavikrīḍita">
                <l n="a"><choice><sic>Ā</sic><corr>A</corr></choice>tyuttuṅga-ka<lb n="8" break="no"/>rīndra-danta-musala-prodbhāsi-rociś cayair</l>
                <l n="b">dhvānta-dhva<supplied reason="omitted">ṁ</supplied>sana-niṣpha<lb n="9" break="no"/>līkr̥ta-śaraccandrodayaiḥ sarvvadā<g ref="sym:bar" type="punctuation">.</g></l>
                <l n="c">yatrāsīd asatī-jana<lb n="10" break="no"/>sya viśadaṁ muktāmayaṁ maṇḍanaṁ</l>
                <l n="d">saṅketāspadam apy atīva dha<lb n="11" break="no"/>vala<supplied reason="omitted">ṁ</supplied> prāsāda-śr̥ṅgāgrataḥ<g ref="sym:doubleBar" type="punctuation">.</g></l>
            </lg>
            <lg n="4" met="upajāti">
                <l n="a">mahānadī-tuṅga-taraṅga-bhaṅga</l>
                <l n="b">-sphā<lb n="12" break="no"/>rocchala<choice><sic>t-s</sic><corr>c-ch</corr></choice>ī<supplied reason="omitted">ka</supplied>ravadbhir āraT</l>
                <l n="c">yasmin ratā<choice><orig>ś</orig><reg>s</reg></choice>aktimad-aṅganānāṁ</l>
                <l n="d">śramāpano<lb n="13" break="no"/>daḥ kriyate marudbhiḥ<g ref="sym:doubleBar" type="punctuation">.</g></l>
            </lg>
             <ab>tasmāT śrī-yayāti-nagarāt<surplus>a</surplus><g ref="sym:bar" type="punctuation">.</g></ab>
            <lg n="5" met="vasantatilakā">
                <l n="a">loka-traya-pra<lb n="14" break="no"/>thita-śubhra-yaśo-vitāna</l>
                <l n="b">-vyāptāṣṭa-dik-prasabha-nirjjita-vairi-varggaḥ<g ref="sym:bar" type="punctuation">.</g></l>
                <l n="c"><lb n="15"/>rājā <choice><orig>v</orig><reg>b</reg></choice>abhūva bhuvi bhāvita-bhavya-m<choice><sic>u</sic><corr>ū</corr></choice>rttiḥ</l>
                <l n="d">śrīmāN saroja-vadano <persName type="king" key="PSN01001">janame<lb n="16" break="no"/>jayā</persName>khyaḥ<g ref="sym:doubleBar" type="punctuation">.</g></l>
            </lg>
            <lg n="6" met="vasantatilakā">
                <l n="a">nirddāritāri-kari-kumbha-samudga-mukta</l>
                <l n="b">-muktāphala-prakara-da<lb n="17" break="no"/>nt<choice><sic>a</sic><corr>u</corr></choice>-rakhaṅga-dhāraḥ</l>
                <l n="c">tasmād aj<choice><sic>a</sic><corr>ā</corr></choice>yata jagat-<supplied reason="omitted">t</supplied>raya-gīta-kīrtti<supplied reason="omitted">r</supplied></l>
                <l n="d">helā-vinirjjita
                    <pb n="2r" break="no"/><lb n="18" break="no"/>-ripu<supplied reason="omitted">r</supplied> nnr̥patir <persName type="king" key="PSN01005">yayātiḥ</persName><g ref="sym:doubleBar" type="punctuation">.</g></l>
            </lg>
            <lg n="7" met="śārdūlavikrīḍita">
                <l n="a">yat-khaḍgāgra-vipāṭita-dvipa-ghaṭā-kumbhastha<lb n="19" break="no"/>lād ullasan</l>
                <l n="b">muktā-jāla-vibhūṣitaṁ prati-raṇaṁ pr̥thvī-vadhūra<supplied reason="omitted">ḥ</supplied> sthalaṁ</l>
                <l n="c">śaśva<lb n="20" break="no"/>d-dv<choice><sic>a</sic><corr>ā</corr></choice>ra-naman-narādhipa-śiroratnā<supplied reason="omitted">ṁ</supplied>śu-jālāmalā</l>
                <l n="d">yat-pādām<choice><orig>v</orig><reg>b</reg></choice>uja-reṇavaḥ sama<lb n="21" break="no"/>tayā tad-raśmi-lakṣmīṁ dadhuḥ<g ref="sym:doubleBar" type="punctuation">.</g></l>
            </lg>
            <lg n="8" met="sragdharā">
                <l n="a">mādya<supplied reason="omitted">l</supplied>-lolāli-mālākula-karaṭa-puṭāsya<lb n="22" break="no"/>ndi-dāna-pravāhāN</l>
                <l n="b">sindūrārakta-kumbhāN śita-pr̥thula-radāN kāmadevādi<lb n="23" break="no"/>saṁjñāN</l>
                <l n="c">jit<choice><sic>y</sic><corr>v</corr></choice>ā 'jāpālam ājau janita-sukhadhū-vismaya<supplied reason="omitted">ḥ</supplied> smera-vaktraḥ</l>
                <l n="d">sa<lb n="24"/>dvātriṁśatkarīndrāN śara-nikara-hat<choice><sic>a</sic><corr>ā</corr></choice>rohakān agrahīd yaḥ<g ref="sym:doubleBar" type="punctuation">.</g></l>
            </lg>
          <p><roleName>parama-mā<lb n="25" break="no"/>heśvara</roleName>-<roleName>parama-bhaṭṭāraka</roleName>-<roleName>mahārājadhirāja</roleName>-<roleName>parameśvara</roleName>-soma-kula<lb n="26" break="no"/>-tilaka-<roleName>trikaliṅgādhipati</roleName>-<roleName>śrī</roleName>-<persName type="king">mahābhavagupta</persName>-<roleName>rāja-deva</roleName>-pādānu<lb n="27" break="no"/>dhyāta-<roleName>parama-māheśvara</roleName>-<roleName>parama-bhaṭṭāraka</roleName>-<roleName>mahārājadhirāja</roleName>-<roleName>pa<lb n="28" break="no"/>rameśvara</roleName>-soma-kula-tilaka-<roleName>trikaliṅgādhipati</roleName>-<roleName>śrī</roleName>-<persName type="king">mahāśivagupta</persName><lb n="29" break="no"/>-<roleName>rājadevaḥ</roleName> kuśalī<g ref="sym:bar" type="punctuation">.</g> ṣaṇṇavatyāṁ telātaṭa-viṣayīyalluttarumā<lb n="30" break="no"/>-grāme tad-viṣayīya-<choice><orig>v</orig><reg>b</reg></choice>rāhmaṇān āpūjya samāhartr̥-sannidhārtr̥-niy<choice><sic>ū</sic><corr>u</corr></choice><lb n="31" break="no"/>ktādhikārika-d<choice><sic>a</sic><corr>ā</corr></choice>ṇḍapā<choice><sic>s</sic><corr>ś</corr></choice>ika-piśuna-v<choice><sic>e</sic><corr>ai</corr></choice>trikāvarodhajana-rāṇa<lb n="32" break="no"/>ka-rājavallabhādīN sarvvān rājapādopajīvinaḥ samājñāpaya<lb n="33" break="no"/>ti viditam astu bhavatām yathāsmābhir ayaṁ grāmaḥ sa-nidhiḥ sopa<lb n="34" break="no"/>nidhiḥ sadaśāparādhaḥ sarvva-<choice><orig>v</orig><reg>b</reg></choice>ādhā-vivarjitaḥ sarvoparikarādā<lb n="35"/>na-sah<choice><sic>ī</sic><corr>i</corr></choice>taḥ<g ref="sym:bar" type="punctuation">.</g> catuḥ-sīmāparyantaḥ sāmra-madhukaḥ sa-gartoṣa
    <pb n="2v" break="no"/><lb n="36" break="no"/>ra<supplied reason="omitted">ḥ</supplied> sa-jala-sthalaḥ pratiniṣiddha-c<choice><orig>a</orig><reg>ā</reg></choice>ṭabhaṭapraveśaḥ kauśi<lb n="37" break="no"/>ka-gotrāya devarāta-Audala-viśvāmitra-pravarāya gautama-śā<lb n="38" break="no"/>khādhyāyine śrāvast<choice><sic>i</sic><corr>ī</corr></choice>-maṇḍale kāsilī-vinirgatāya lāvaṭāvi<lb n="39" break="no"/>ṣayentaraḍi vāstavyāya-parameśvaranaptne siddheśvara-sutā<lb n="40" break="no"/>ya bhaṭṭa-śrīmahedadhaye Udakadhārāpuraḥ sara<choice><sic>Ā</sic><corr>m ā</corr></choice>candra<lb n="41" break="no"/>-tārakārka-kṣiti-samakālopabhogārthaṁ mātāpitror ātmana<lb n="42" break="no"/>ś ca puṇya-yaśo 'bhivr̥ddhaye tām<surplus>v</surplus>ra-śā<choice><orig>ś</orig><reg>s</reg></choice>anenākarīkr̥tya pratipād<choice><sic>a</sic><corr>i</corr></choice><lb n="43" break="no"/>ta Ity avagatya samucita-kara-nikara-bhoga-bhāgādikam u<lb n="44" break="no"/>panayadhiḥ sukhaṁ prativastavyam iti<g ref="sym:doubleBar" type="punctuation">.</g> bhāvibhi<lb n="45" break="no"/>ś ca bhūpatibhir ddattir iyam asmadīyā dharmma-gauravād asmad anu<lb n="46" break="no"/>rodhāc ca sva-dattir ivānupālanīyā<g ref="sym:doubleBar" type="punctuation">.</g> tathā coktaṁ dharmmaśastre</p>
            <lg n="10" met="anuṣṭubh"><!--corresp="#Sircar1965_st0023"  -->
                <l n="a"><choice><orig>v</orig><reg>b</reg></choice>ahubhi<lb n="47" break="no"/>r vasudhā dattā</l>
                   <l n="b">rājabhiḥ sagar<choice><sic>a</sic><corr>ā</corr></choice>dibhiḥ<g ref="sym:bar" type="punctuation">.</g></l>
                   <l n="c">yasya yasya yadā bhūmis</l>
                   <l n="d">tasya ta<lb n="48" break="no"/>sya tadā phalaṁ<g ref="sym:doubleBar" type="punctuation">.</g></l><!-- 
                    amwb: Sircar 23
                     -->
            </lg>
            <lg n="11" met="anuṣṭubh"><!-- corresp="#Sircar1965_st0085" -->                
